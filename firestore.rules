rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User profile: User can only read/write their own auth profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Restaurants: Only the owner (the creator) can read or modify
    match /restaurants/{restaurantId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
    }
    
    // Outlets: Owner can manage all. Staff can read outlets they belong to.
    match /outlets/{outletId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        resource == null || 
        resource.data.ownerId == request.auth.uid || 
        request.resource.data.ownerId == request.auth.uid
      );
    }
    
    // Employees: Users can read their own employee record or records in their outlet.
    match /employees/{employeeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        resource == null ||
        resource.data.ownerId == request.auth.uid ||
        request.resource.data.ownerId == request.auth.uid ||
        employeeId == request.auth.uid
      );
    }
    
    // Orders & Inventory: Allow reads/writes only if the user belongs to the associated outlet
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    
    match /inventory_items/{itemId} {
      allow read, write: if request.auth != null;
    }

    // Immutable Audit Logs ledger: write-only, read-restricted, no deletes/updates
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (resource == null || resource.data.ownerId == request.auth.uid);
      allow update, delete: if false;
    }
  }
}
